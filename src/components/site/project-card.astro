---
interface ProjectLink {
  label: string
  href: string
}

interface Props {
  name: string
  description: string
  links: ProjectLink[]
}

const { name, description, links } = Astro.props
---

<article class="border-border bg-card rounded-lg border p-6 md:p-10">
  <h3 class="font-display text-heading text-foreground">
    {name}
  </h3>
  <p class="text-muted-foreground text-body mt-4">
    {description}
  </p>
  <ul class="mt-6 flex flex-wrap gap-x-6 gap-y-2">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-foreground text-label hover:text-primary underline-offset-4 hover:underline"
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</article>
