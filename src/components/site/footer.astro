---
import signatureSvg from '@/assets/footer/signature.svg?raw'

const year = new Date().getFullYear()
---

<footer class="px-6 pb-10 md:pb-16">
  <div
    class="border-border mx-auto max-w-2xl border-t pt-10 md:pt-12 lg:max-w-5xl"
  >
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:gap-12">
      <p
        class="font-display text-foreground text-[clamp(2rem,_4vw_+_1rem,_3rem)] leading-none font-semibold"
      >
        Eric Le
      </p>
      <div
        data-signature
        aria-hidden="true"
        class="text-foreground aspect-[716/255] w-24 max-w-full [&>svg]:block [&>svg]:size-full"
        set:html={signatureSvg}
      >
      </div>
    </div>
    <div
      class="mt-8 flex flex-col gap-4 md:mt-10 md:flex-row md:items-center md:justify-between"
    >
      <a
        href="/resume.pdf"
        target="_blank"
        rel="noopener"
        class="text-foreground text-label hover:text-primary underline-offset-4 hover:underline"
      >
        Résumé
      </a>
      <p class="text-muted-foreground text-label font-normal italic">
        Set in Fraunces and Inter · Gothenburg, {year}
      </p>
    </div>
  </div>
</footer>

<script>
  import { initFooterSignature } from './footer-signature'

  initFooterSignature()
</script>
