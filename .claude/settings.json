{
  "permissions": {
    "allow": [
      "Bash(bun run check:spell)",
      "Bash(bun run check:format)",
      "Bash(bun run check:shell)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/standards-audit.sh"
          }
        ]
      }
    ]
  }
}
