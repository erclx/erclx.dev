---
const links = [
  { label: 'GitHub', href: 'https://github.com/erclx' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/erclx' },
  { label: 'me@erclx.dev', href: 'mailto:me@erclx.dev' },
]

const year = new Date().getFullYear()
---

<footer class="px-6 pb-12 md:pb-16">
  <div
    class="border-border mx-auto flex max-w-2xl flex-col gap-6 border-t pt-12 md:flex-row md:items-center md:justify-between md:pt-16"
  >
    <ul class="flex flex-wrap gap-x-6 gap-y-2">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-foreground text-label hover:text-primary underline-offset-4 hover:underline"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
    <p class="text-muted-foreground text-label">
      © {year} Eric Le · Gothenburg, Sweden
    </p>
  </div>
</footer>
