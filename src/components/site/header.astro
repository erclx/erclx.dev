---
import ThemeToggle from '@/components/site/theme-toggle.astro'

const links = [
  { label: 'GitHub', href: 'https://github.com/erclx' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/erclx' },
  { label: 'me@erclx.dev', href: 'mailto:me@erclx.dev' },
]
---

<header
  class="bg-secondary flex rounded-b-3xl px-6 pt-20 pb-16 md:min-h-[80vh] md:items-center md:pt-32 md:pb-20"
>
  <div class="mx-auto w-full max-w-2xl">
    <div data-fade class="flex items-start justify-between gap-4">
      <span
        class="text-muted-foreground text-label inline-flex items-center gap-2 tracking-wide uppercase"
      >
        <span
          class="bg-chart-2 inline-block size-2 rounded-full"
          aria-hidden="true"></span>
        Open to work
      </span>
      <ThemeToggle />
    </div>
    <div data-fade style="--fade-delay: 150ms">
      <p
        class="text-muted-foreground text-label mt-2 tracking-wide uppercase"
      >
        Eric Le · Gothenburg, Sweden
      </p>
      <h1 class="font-display text-display text-foreground mt-6">
        I build LLM applications and developer tools.
      </h1>
    </div>
    <div data-fade style="--fade-delay: 300ms">
      <p class="text-muted-foreground text-body mt-6 max-w-xl">
        Applied AI engineer working in LLM applications and prompt engineering.
        Spent 1.5 years building natural language data agents at Volvo across
        three engagements, with a second team picking up the work for the
        final contract. Published two developer tools: a VS Code extension and
        a Chrome extension.
      </p>
      <ul class="mt-10 flex flex-wrap gap-x-6 gap-y-2">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-foreground text-label hover:text-primary underline-offset-4 hover:underline"
            >
              {link.label}
            </a>
          </li>
        ))
      }
      </ul>
    </div>
  </div>
</header>
