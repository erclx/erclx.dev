---
const year = new Date().getFullYear()
---

<footer class="px-6 pb-10 md:pb-16">
  <div
    class="border-border mx-auto flex max-w-2xl flex-col gap-4 border-t pt-10 md:flex-row md:items-center md:justify-between md:pt-16 lg:max-w-5xl"
  >
    <a
      href="/resume.pdf"
      target="_blank"
      rel="noopener"
      class="text-foreground text-label hover:text-primary underline-offset-4 hover:underline"
    >
      Résumé (PDF)
    </a>
    <p class="text-muted-foreground text-label">
      © {year} Eric Le · Gothenburg, Sweden
    </p>
  </div>
</footer>
