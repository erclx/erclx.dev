---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface ProjectLink {
  label: string
  href: string
}

interface Props {
  name: string
  description: string
  poster?: ImageMetadata
  videoSrc?: string
  mediaAlt?: string
  mediaPosition?: string
  links: ProjectLink[]
  index?: number
}

const {
  name,
  description,
  poster,
  videoSrc,
  mediaAlt,
  mediaPosition = 'top',
  links,
  index = 0,
} = Astro.props

const fadeDelay = `${index * 200}ms`
---

<article
  data-fade
  data-tilt
  style={`--fade-delay: ${fadeDelay}`}
  class="border-border hover:border-foreground/30 bg-card group/card relative overflow-hidden rounded-lg border transition-colors duration-200 [transform:perspective(900px)_rotateX(var(--tilt-x,0deg))_rotateY(var(--tilt-y,0deg))] [transform-style:preserve-3d] [will-change:transform]"
>
  {
    poster && videoSrc && mediaAlt && (
      <div
        data-media-slot
        class="bg-muted/40 relative aspect-[11/7] overflow-hidden border-b border-border/60 p-2 sm:p-3"
      >
        <div class="ring-border/40 relative size-full overflow-hidden rounded-md shadow-sm ring-1 [transform:translate3d(var(--parallax-x,0),var(--parallax-y,0),0)] [will-change:transform]">
          <Image
            src={poster}
            alt={mediaAlt}
            style={`object-position: ${mediaPosition}`}
            class="absolute inset-0 size-full object-cover"
            data-media-poster
          />
          <video
            src={videoSrc}
            poster={poster.src}
            muted
            loop
            playsinline
            preload="none"
            aria-hidden="true"
            style={`object-position: ${mediaPosition}`}
            class="absolute inset-0 size-full object-cover opacity-0 transition-opacity duration-200 group-hover/card:opacity-100"
            data-media-video
          />
        </div>
      </div>
    )
  }
  <div class="p-6 md:p-10">
    <h3 class="font-display text-heading text-foreground">
      {name}
    </h3>
    <p class="text-muted-foreground text-body mt-4">
      {description}
    </p>
    <ul class="mt-6 flex flex-wrap gap-x-6 gap-y-2">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-foreground text-label underline-offset-4 hover:underline"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</article>
