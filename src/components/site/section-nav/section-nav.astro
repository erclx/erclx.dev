---
interface SectionNavItem {
  readonly id: string
  readonly label: string
}

interface Props {
  items?: readonly SectionNavItem[]
  instant?: boolean
}

const {
  items = [
    { id: 'origin', label: 'origin' },
    { id: 'projects', label: 'projects' },
    { id: 'looking-for', label: 'looking-for' },
  ],
  instant = false,
} = Astro.props
---

<nav
  data-section-nav
  data-instant={instant ? 'true' : undefined}
  data-revealed={instant ? 'true' : undefined}
  aria-label="Sections"
  class="section-nav fixed top-1/2 left-6 z-20 hidden -translate-y-1/2 flex-col gap-3 xl:flex"
>
  {
    items.map((item) => (
      <a
        href={`#${item.id}`}
        data-target={item.id}
        class="section-nav-link text-muted-foreground font-mono text-label -ml-3 border-l-2 border-transparent pl-3"
      >
        {item.label}
      </a>
    ))
  }
</nav>

<style>
  .section-nav {
    opacity: 0;
    pointer-events: none;
  }
  .section-nav[data-revealed='true'] {
    opacity: 1;
    pointer-events: auto;
  }
  .section-nav[data-near-footer='true'] {
    opacity: 0;
    pointer-events: none;
  }
  .section-nav-link {
    transition:
      color 150ms ease-out,
      border-color 150ms ease-out;
  }
  .section-nav-link:hover {
    color: var(--foreground);
  }
  .section-nav-link[data-active='true'] {
    color: var(--foreground);
    border-color: var(--primary);
  }
  @media (prefers-reduced-motion: no-preference) {
    .section-nav:not([data-instant]) {
      transition: opacity 300ms ease-out;
    }
  }
</style>

<script>
  const nav = document.querySelector<HTMLElement>('[data-section-nav]')
  if (nav && 'IntersectionObserver' in window) {
    const links = Array.from(
      nav.querySelectorAll<HTMLAnchorElement>('.section-nav-link'),
    )
    const sections = links
      .map((link) => {
        const id = link.dataset.target
        return id ? document.getElementById(id) : null
      })
      .filter((el): el is HTMLElement => el !== null)

    const setActive = (id: string | null) => {
      for (const link of links) {
        if (link.dataset.target === id) {
          link.setAttribute('data-active', 'true')
          link.setAttribute('aria-current', 'location')
        } else {
          link.removeAttribute('data-active')
          link.removeAttribute('aria-current')
        }
      }
    }

    const ANCHOR_RATIO = 0.3
    const CLICK_LOCK_MS = 700
    let scrollFrame: number | null = null
    let clickLockUntil = 0

    const computeActive = () => {
      scrollFrame = null
      if (performance.now() < clickLockUntil) return
      const atBottom =
        window.scrollY + window.innerHeight >=
        document.documentElement.scrollHeight - 4
      if (atBottom && sections.length > 0) {
        setActive(sections[sections.length - 1].id)
        return
      }
      const anchor = window.innerHeight * ANCHOR_RATIO
      let activeId: string | null = null
      for (const section of sections) {
        const top = section.getBoundingClientRect().top
        if (top <= anchor) {
          activeId = section.id
        } else {
          break
        }
      }
      setActive(activeId)
    }

    const scheduleCompute = () => {
      if (scrollFrame === null) {
        scrollFrame = window.requestAnimationFrame(computeActive)
      }
    }

    window.addEventListener('scroll', scheduleCompute, { passive: true })
    window.addEventListener('resize', scheduleCompute)
    computeActive()

    const isInstant = nav.dataset.instant === 'true'
    if (!isInstant) {
      const footer = document.querySelector<HTMLElement>(
        '[data-section="footer"]',
      )
      if (footer) {
        const footerObserver = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                nav.setAttribute('data-near-footer', 'true')
              } else {
                nav.removeAttribute('data-near-footer')
              }
            }
          },
          { threshold: 0, rootMargin: '0px 0px -50% 0px' },
        )
        footerObserver.observe(footer)
      }

      const hero = document.querySelector<HTMLElement>(
        '[data-section="header"]',
      )
      if (hero) {
        const heroObserver = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                nav.removeAttribute('data-revealed')
              } else {
                nav.setAttribute('data-revealed', 'true')
              }
            }
          },
          { threshold: 0, rootMargin: '-50% 0px 0px 0px' },
        )
        heroObserver.observe(hero)
      }
    }

    for (const link of links) {
      link.addEventListener('click', (e) => {
        const id = link.dataset.target
        if (!id) return
        const target = document.getElementById(id)
        if (!target) return
        e.preventDefault()
        setActive(id)
        clickLockUntil = performance.now() + CLICK_LOCK_MS
        target.scrollIntoView({ behavior: 'smooth', block: 'start' })
      })
    }
  }
</script>
