---
const criteria = [
  {
    label: 'roles',
    value: 'AI tooling, LLM applications, developer experience',
  },
  {
    label: 'setup',
    value:
      'Small to mid teams that take AI-assisted dev seriously. Gothenburg or remote, Swedish or English-speaking teams.',
  },
  {
    label: 'level',
    value:
      'Junior to mid. 18 months applied LLM at Volvo plus published side projects.',
  },
]
---

<section
  data-section="looking-for"
  class="px-6 pt-16 pb-24 md:pt-20 md:pb-32"
  data-scroll-reveal
>
  <div class="mx-auto max-w-2xl">
    <div class="border-border bg-card rounded-lg border p-6 md:p-10">
      <p
        data-fade
        class="text-muted-foreground font-mono text-label"
      >
        looking-for
      </p>
      <dl class="mt-6 grid gap-y-4">
        {
          criteria.map((item, idx) => (
            <div
              data-fade
              style={`--fade-delay: ${150 + idx * 100}ms`}
              class="group -ml-4 grid gap-x-10 border-l-2 border-transparent pl-4 hover:border-primary sm:grid-cols-[8rem_1fr]"
            >
              <dt class="text-muted-foreground group-hover:text-foreground font-mono text-label">
                {item.label}
              </dt>
              <dd class="text-foreground text-body">{item.value}</dd>
            </div>
          ))
        }
      </dl>
      <div
        data-fade
        style="--fade-delay: 600ms"
        class="border-border mt-10 border-t pt-6"
      >
        <p class="text-muted-foreground font-mono text-label">availability</p>
        <p class="text-foreground mt-2 font-mono text-body font-semibold">
          <span class="text-primary" aria-hidden="true">▸</span><span
            data-typewriter>Available immediately, full-time or contract</span
          ><span class="cursor-blink" aria-hidden="true">_</span>
        </p>
      </div>
      <div
        data-fade
        style="--fade-delay: 750ms"
        class="border-border mt-10 border-t pt-4"
      >
        <p class="text-muted-foreground font-mono text-label">
          EU citizen · no sponsorship · Swedish, English native · Vietnamese
          limited
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .cursor-blink {
    display: inline-block;
    animation: looking-for-cursor 1.1s steps(2) infinite;
  }
  @keyframes looking-for-cursor {
    50% {
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .cursor-blink {
      animation: none;
    }
  }
</style>

<script>
  const target = document.querySelector<HTMLElement>('[data-typewriter]')
  if (target) {
    const fullText = target.textContent ?? ''
    const reduce = window.matchMedia(
      '(prefers-reduced-motion: reduce)',
    ).matches
    if (!reduce) {
      target.textContent = ''
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              observer.unobserve(entry.target)
              let i = 0
              const interval = window.setInterval(() => {
                i += 1
                target.textContent = fullText.slice(0, i)
                if (i >= fullText.length) {
                  window.clearInterval(interval)
                }
              }, 25)
            }
          }
        },
        { threshold: 0.1 },
      )
      observer.observe(target)
    }
  }
</script>
