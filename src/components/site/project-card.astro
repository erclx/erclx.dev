---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface ProjectLink {
  label: string
  href: string
}

interface Props {
  name: string
  description: string
  imageLight?: ImageMetadata
  imageDark?: ImageMetadata
  imageAlt?: string
  links: ProjectLink[]
  index?: number
}

const {
  name,
  description,
  imageLight,
  imageDark,
  imageAlt,
  links,
  index = 0,
} = Astro.props

const fadeDelay = `${index * 200}ms`
---

<article
  data-fade
  style={`--fade-delay: ${fadeDelay}`}
  class="border-border hover:border-foreground/30 bg-card overflow-hidden rounded-lg border transition duration-200 hover:-translate-y-0.5"
>
  {
    imageLight && imageDark && imageAlt && (
      <div class="border-border bg-muted aspect-[11/7] border-b">
        <Image
          src={imageLight}
          alt={imageAlt}
          class="size-full object-cover dark:hidden"
        />
        <Image
          src={imageDark}
          alt=""
          aria-hidden="true"
          class="hidden size-full object-cover dark:block"
        />
      </div>
    )
  }
  <div class="p-6 md:p-10">
    <h3 class="font-display text-heading text-foreground">
      {name}
    </h3>
    <p class="text-muted-foreground text-body mt-4">
      {description}
    </p>
    <ul class="mt-6 flex flex-wrap gap-x-6 gap-y-2">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-foreground text-label hover:text-primary underline-offset-4 hover:underline"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</article>
