---
import ProjectCard from '@/components/site/project-card.astro'
import stackrPoster from '@/assets/projects/stackr.png'
import caretPoster from '@/assets/projects/caret.png'
import stackrVideo from '@/assets/videos/stackr.mp4?url'
import caretVideo from '@/assets/videos/caret.mp4?url'

const projects = [
  {
    name: 'Stackr',
    description:
      'VS Code extension for multi-file LLM context preparation. 1,000+ downloads on Open VSX. Drag-and-drop file staging, live token counting, pinned files that survive session restarts.',
    poster: stackrPoster,
    videoSrc: stackrVideo,
    mediaAlt: 'Stackr — VS Code panel showing staged files and a context preview',
    links: [
      {
        label: 'VS Code Marketplace',
        href: 'https://marketplace.visualstudio.com/items?itemName=erclx.ai-context-stacker',
      },
      {
        label: 'Open VSX',
        href: 'https://open-vsx.org/extension/erclx/ai-context-stacker',
      },
      { label: 'GitHub', href: 'https://github.com/erclx/stackr' },
    ],
  },
  {
    name: 'Caret',
    description:
      'Chrome extension for saving and invoking prompts in Claude, Gemini, and ChatGPT. Trigger-symbol search and keyboard-driven injection from a command-palette dropdown anchored on the chat input.',
    poster: caretPoster,
    videoSrc: caretVideo,
    mediaAlt: 'Caret — chat input showing a trigger-character palette of saved prompts',
    links: [
      {
        label: 'Chrome Web Store',
        href: 'https://chromewebstore.google.com/detail/caret/bpmdbibldelkpncegllkeegdpblgehgk',
      },
      { label: 'GitHub', href: 'https://github.com/erclx/caret' },
    ],
  },
]
---

<section class="px-6 py-16 md:py-20" data-scroll-reveal>
  <div class="mx-auto max-w-2xl lg:max-w-5xl">
    <h2
      data-fade
      class="font-display text-foreground text-[2.25rem] leading-tight font-semibold md:text-[2.75rem]"
    >
      Projects
    </h2>
    <div class="mt-10 grid gap-6 lg:mt-14 lg:grid-cols-2">
      {
        projects.map((project, index) => {
          const numeral = String(index + 1).padStart(2, '0')
          const isLeftCol = index % 2 === 0
          const fadeDelay = `${index * 200}ms`
          return (
            <div class="relative">
              <span
                aria-hidden="true"
                data-fade
                style={`--fade-delay: ${fadeDelay}`}
                class:list={[
                  'font-display pointer-events-none absolute z-10 leading-none font-semibold select-none',
                  'top-3 right-5 text-[5rem] text-stone-500/50 dark:text-foreground/12',
                  'lg:top-0 lg:text-[8rem] lg:text-stone-500/65 lg:dark:text-foreground/15',
                  isLeftCol
                    ? 'lg:right-auto lg:-left-12'
                    : 'lg:left-auto lg:-right-12',
                ]}
              >
                {numeral}
              </span>
              <ProjectCard
                name={project.name}
                description={project.description}
                poster={project.poster}
                videoSrc={project.videoSrc}
                mediaAlt={project.mediaAlt}
                links={project.links}
                index={index}
              />
            </div>
          )
        })
      }
    </div>
    <p
      data-fade
      style="--fade-delay: 400ms"
      class="text-muted-foreground text-body mt-6"
    >
      Plus <a
        href="https://github.com/erclx/toolkit"
        class="text-foreground hover:text-primary underline underline-offset-4"
        >Toolkit</a
      >, an agent-first CLI that installs and syncs governance, skills, and
      standards across projects.
    </p>
  </div>
</section>

<script>
  const targets = document.querySelectorAll<HTMLElement>('[data-fade]')
  if (targets.length > 0 && 'IntersectionObserver' in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.setAttribute('data-visible', 'true')
            observer.unobserve(entry.target)
          }
        }
      },
      { threshold: 0.15, rootMargin: '0px 0px -10% 0px' },
    )
    for (const target of targets) {
      observer.observe(target)
    }
  }
</script>

<script>
  import { initProjectMedia } from './project-media'
  import { initTilt } from './tilt'

  initProjectMedia()
  initTilt()
</script>
